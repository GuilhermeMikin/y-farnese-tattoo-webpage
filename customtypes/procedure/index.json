{
  "format": "custom",
  "id": "procedure",
  "label": "Procedure",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": "ex: fine-line"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Nome do estilo ou página",
          "useAsTitle": true
        }
      },
      "category": {
        "type": "Text",
        "config": {
          "label": "Category",
          "placeholder": "Fine Line"
        }
      },
      "summary": {
        "type": "StructuredText",
        "config": {
          "label": "Summary",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em"
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "allowTargetBlank": true,
          "multi": "paragraph,heading2,heading3,strong,em,list-item,o-list-item"
        }
      },
      "cta_label": {
        "type": "Text",
        "config": {
          "label": "CTA Label",
          "placeholder": "Agendar procedimento"
        }
      },
      "before_after_gallery": {
        "type": "Group",
        "config": {
          "label": "Portfolio Gallery",
          "fields": {
            "image": {
              "type": "Image",
              "config": {
                "label": "Image",
                "constraint": {
                  "width": 0
                },
                "thumbnails": []
              }
            },
            "image_alt": {
              "type": "Text",
              "config": {
                "label": "Alt Text",
                "placeholder": "Texto alternativo da imagem do portfolio"
              }
            }
          }
        }
      }
    }
  }
}
