{
  "format": "custom",
  "id": "site_settings",
  "label": "Configurações do Site",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "brand_name": {
        "type": "Text",
        "config": {
          "label": "Nome da marca",
          "placeholder": "Yolanda Farnese",
          "useAsTitle": true
        }
      },
      "tagline": {
        "type": "Text",
        "config": {
          "label": "Slogan",
          "placeholder": "Tattoo Artist - Fine Line & Blackwork"
        }
      },
      "primary_cta_label": {
        "type": "Text",
        "config": {
          "label": "Texto do botão principal",
          "placeholder": "Agendar atendimento"
        }
      },
      "whatsapp_link": {
        "type": "Link",
        "config": {
          "label": "Link do WhatsApp",
          "select": "web"
        }
      },
      "instagram_link": {
        "type": "Link",
        "config": {
          "label": "Link do Instagram",
          "select": "web"
        }
      },
      "maps_link": {
        "type": "Link",
        "config": {
          "label": "Link do Google Maps",
          "select": "web"
        }
      },
      "address_label": {
        "type": "Text",
        "config": {
          "label": "Endereço (curto)",
          "placeholder": "Uberlândia - MG"
        }
      },
      "address_full": {
        "type": "Text",
        "config": {
          "label": "Endereço completo",
          "placeholder": "Uberlândia - MG"
        }
      }
    }
  }
}
